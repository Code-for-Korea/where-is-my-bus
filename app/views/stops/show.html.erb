<div data-controller="bus-selector arrival-polling"
     data-arrival-polling-url-value="<%= stop_arrival_json_path(region_slug: params[:region_slug], stop_id: params[:stop_id]) %>"
     data-arrival-polling-no-data-line1-value="<%= j t('stops.show.no_data_line1') %>"
     data-arrival-polling-no-data-line2-value="<%= j t('stops.show.no_data_line2') %>"
     data-arrival-polling-arrived-line1-value="<%= j t('stops.show.arrived_line1') %>"
     data-arrival-polling-arrived-line2-value="<%= j t('stops.show.arrived_line2') %>"
     data-arrival-polling-stops-away-suffix-value="<%= j t('stops.show.stops_away_suffix') %>"
     data-arrival-polling-eta-prefix-value="<%= j t('stops.show.eta_prefix') %>"
     data-arrival-polling-eta-suffix-before-value="<%= j t('stops.show.eta_suffix_before') %>"
     data-arrival-polling-eta-suffix-after-value="<%= j t('stops.show.eta_suffix_after') %>"
     data-bus-selector-select-error-message-value="<%= j t('shared.bus_selector_sheet.select_error') %>"
     class="flex flex-col h-screen">

  <%# 헤더 %>
  <div class="pr-6 pt-12 pb-3 bg-white flex-shrink-0">
    <div class="flex items-center gap-2">
      <%= link_to root_path, class: "text-gray-400 hover:text-gray-600 transition-colors text-xl leading-none flex-shrink-0 pl-4" do %>
        ←
      <% end %>
      <span class="text-lg font-bold text-gray-900 truncate"><%= t("stops.show.title") %></span>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500 flex-shrink-0">
        <path d="M8 6v6"/><path d="M15 6v6"/><path d="M2 12h19.6"/>
        <path d="M18 18h3s.5-1.7.8-2.8c.1-.4.2-.8.2-1.2 0-.4-.1-.8-.2-1.2l-1.4-5C20.1 6.8 19.1 6 18 6H4a2 2 0 0 0-2 2v10h3"/>
        <circle cx="7" cy="18" r="2"/><path d="M9 18h5"/><circle cx="16" cy="18" r="2"/>
      </svg>
      <%= render "shared/locale_switcher" %>
    </div>
  </div>

  <%# 상단 — 정류장 정보 (회색 패널) %>
  <div class="bg-gray-50 px-6 pt-10 pb-12 flex-shrink-0">
    <p class="text-sm text-gray-400 mb-3"><%= t("stops.show.here_region", region_name: [@region&.display_name, @area&.name].compact.join(" ")) %></p>

    <%# 버스번호 + SVG 드롭다운 %>
    <div class="flex items-center gap-1 mb-2">
      <button data-action="click->bus-selector#open" class="flex items-center gap-1 group">
        <span class="text-3xl font-bold text-indigo-600 group-hover:text-indigo-700 transition-colors"><%= t("stops.show.bus_number_label", bus_number: @bus&.display_number) %></span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
             class="w-6 h-6 text-indigo-400 group-hover:text-indigo-600 transition-colors mt-1">
          <path fill-rule="evenodd"
                d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
                clip-rule="evenodd" />
        </svg>
      </button>
    </div>

    <h2 class="text-3xl font-black text-gray-900 mb-4"><%= @stop&.display_name %></h2>

    <div data-controller="like-button"
         data-like-button-url-value="<%= stop_like_path(region_slug: params[:region_slug], stop_id: params[:stop_id]) %>"
         data-like-button-liked-value="<%= @already_liked %>">
      <button data-action="click->like-button#like"
              data-like-button-target="button"
              class="flex items-center gap-1.5 text-indigo-500 transition-opacity <%= 'opacity-40 cursor-not-allowed' if @already_liked %>">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z"/>
          <path d="M7 10v12"/>
        </svg>
        <span class="text-sm font-medium" data-like-button-target="count"><%= @likes_count %></span>
      </button>
    </div>
  </div>

  <%# 하단 — 도착 예측 (파란 패널, 나머지 공간) %>
  <div class="bg-blue-600 flex-1 px-6 pt-14 pb-6 flex flex-col">

    <p class="text-blue-200 text-base mb-6"><%= t("stops.show.bus_location_label", bus_number: @bus&.display_number) %></p>

    <div class="flex-1">
      <p class="text-white text-xl font-medium mb-2"
         data-arrival-polling-target="stopsAway">
      </p>
      <p class="text-white font-extrabold leading-tight mb-2"
         style="font-size: 2.5rem;"
         data-arrival-polling-target="eta">
        <%= t("stops.show.no_data_line1") %><br><%= t("stops.show.no_data_line2") %>
      </p>

      <% if Rails.env.development? %>
      <%# DEBUG PANEL — 개발 환경 전용 %>
      <% base_seq = @stop&.sequence.to_i %>
      <details class="mt-4 bg-amber-50 border border-amber-300 rounded-2xl text-xs overflow-hidden">
        <summary class="px-4 py-2 font-bold text-amber-700 cursor-pointer select-none">🛠 <%= t("stops.show.debug_title") %></summary>
        <div class="px-4 pb-4 pt-2">
          <p class="text-amber-600 mb-3"><%= t("stops.show.debug_current_seq", seq: base_seq) %></p>
          <div class="flex gap-2 mb-3">
            <button onclick="debugBus(<%= base_seq - 3 %>)"
                    class="flex-1 bg-amber-400 hover:bg-amber-500 text-white font-bold py-2 rounded-xl transition-colors">
              -3
            </button>
            <button onclick="debugBus(<%= base_seq - 2 %>)"
                    class="flex-1 bg-amber-400 hover:bg-amber-500 text-white font-bold py-2 rounded-xl transition-colors">
              -2
            </button>
            <button onclick="debugBus(<%= base_seq - 1 %>)"
                    class="flex-1 bg-amber-400 hover:bg-amber-500 text-white font-bold py-2 rounded-xl transition-colors">
              -1
            </button>
            <button onclick="debugBus(<%= base_seq - 1 %>, 70)"
                    class="flex-1 bg-orange-400 hover:bg-orange-500 text-white font-bold py-2 rounded-xl transition-colors">
              근접
            </button>
            <button onclick="debugBus(<%= base_seq %>)"
                    class="flex-1 bg-red-400 hover:bg-red-500 text-white font-bold py-2 rounded-xl transition-colors">
              도착
            </button>
          </div>
          <div id="debug-result" class="bg-white rounded-xl p-3 text-gray-700 leading-relaxed hidden"></div>
        </div>
      </details>
      <% end %>
    </div>

    <%# 자세히보기 — Turbo Frame으로 P2 위에 오버레이 %>
    <div class="flex justify-end mb-5">
      <%= link_to stop_detail_path(region_slug: params[:region_slug], stop_id: params[:stop_id]),
            data: { turbo_frame: "detail-modal" },
            class: "bg-indigo-500 hover:bg-indigo-400 text-white text-sm font-bold px-5 py-2.5 rounded-xl transition-colors" do %>
        <%= t("stops.show.see_detail") %>
      <% end %>
    </div>

    <%# 노선 진행 바 — 현재 정류장 기준 -3/-2/-1/현재 %>
    <div class="relative h-14">
      <%# 배경 라인 %>
      <div class="absolute inset-x-0 top-1/2 h-0.5 bg-white/30 -translate-y-1/2"></div>

      <%# 고정 점: -3 (0%), -2 (15%), -1 (30%) — 우측 70%는 현재 정류장 접근 구간 %>
      <div class="absolute top-1/2 left-[0%]  -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-white/50 z-10"></div>
      <div class="absolute top-1/2 left-[15%] -translate-x-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-white/50 z-10"></div>
      <div class="absolute top-1/2 left-[30%] -translate-x-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-white/50 z-10"></div>

      <%# 목적지 핀 (현재 정류장, 우측) %>
      <div class="absolute right-0 -top-1 z-10 flex flex-col items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <div class="w-3 h-3 rounded-full bg-white mt-0.5"></div>
      </div>

      <%# 버스 아이콘 — stops_away 기반 left% 업데이트 %>
      <div class="absolute -top-[3px] z-20 flex flex-col items-center -translate-x-1/2 transition-all duration-500"
           style="left: 50%"
           data-arrival-polling-target="busMarker">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 6v6"/><path d="M15 6v6"/><path d="M2 12h19.6"/>
          <path d="M18 18h3s.5-1.7.8-2.8c.1-.4.2-.8.2-1.2 0-.4-.1-.8-.2-1.2l-1.4-5C20.1 6.8 19.1 6 18 6H4a2 2 0 0 0-2 2v10h3"/>
          <circle cx="7" cy="18" r="2"/><path d="M9 18h5"/><circle cx="16" cy="18" r="2"/>
        </svg>
      </div>
    </div>

  </div>

  <% if Rails.env.development? %>
  <script>
    const i18n = {
      arrivedLine1: "<%= j t("stops.show.arrived_line1") %>",
      arrivedLine2: "<%= j t("stops.show.arrived_line2") %>",
      none:         "<%= j t("stops.show.debug_none") %>",
      unit_min:     "<%= j t("stops.show.unit_min") %>",
      unit_stops:   "<%= j t("stops.show.unit_stops") %>"
    }

    async function debugBus(seq, pct = 0) {
      const url  = "<%= stop_debug_bus_path(region_slug: params[:region_slug], stop_id: params[:stop_id]) %>"
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      const res  = await fetch(`${url}?seq=${seq}&pct=${pct}`, { method: "POST", headers: { "X-CSRF-Token": csrf, "Accept": "application/json" } })
      const d    = await res.json()

      const marker = document.querySelector('[data-arrival-polling-target="busMarker"]')
      if (marker && d.bar_pct != null) marker.style.left = `${d.bar_pct}%`

      const stopsAway = document.querySelector('[data-arrival-polling-target="stopsAway"]')
      const eta       = document.querySelector('[data-arrival-polling-target="eta"]')
      if (d.stops_away === 0) {
        if (stopsAway) stopsAway.innerHTML = ''
        if (eta)       eta.innerHTML = `${i18n.arrivedLine1}<br>${i18n.arrivedLine2}`
      } else {
        if (stopsAway) stopsAway.innerHTML = `${d.stops_away} <%= j t("stops.show.stops_away_suffix") %>`
        if (eta)       eta.innerHTML = `<%= j t("stops.show.eta_prefix") %>${d.eta_minutes}<%= j t("stops.show.eta_suffix_before") %><br><%= j t("stops.show.eta_suffix_after") %>`
      }

      const el = document.getElementById("debug-result")
      el.classList.remove("hidden")
      el.innerHTML = `
        <p><strong><%= j t("stops.show.debug_bus_location") %>:</strong> ${d.bus_stop}${pct > 0 ? ' → ' + pct + '%' : ''}</p>
        <p><strong><%= j t("stops.show.debug_coordinates") %>:</strong> ${d.bus_lat?.toFixed(4)}, ${d.bus_lng?.toFixed(4)}</p>
        <p><strong><%= j t("stops.show.debug_target") %>:</strong> ${d.target_stop}</p>
        <p><strong><%= j t("stops.show.debug_via") %>:</strong> ${(d.via||[]).join(' → ') || i18n.none}</p>
        <p><strong><%= j t("stops.show.debug_eta") %>:</strong> ${d.eta_minutes}${i18n.unit_min} / ${d.stops_away}${i18n.unit_stops} ${d.message ? '('+d.message+')' : ''}</p>
        <p><strong><%= j t("stops.show.debug_bar") %>:</strong> ${d.bar_pct}%</p>
      `
    }
  </script>
  <% end %>

  <%# 노선 자세히보기 모달 — Turbo Frame 컨테이너 %>
  <turbo-frame id="detail-modal"></turbo-frame>

  <%# 바텀시트 오버레이 %>
  <div data-bus-selector-target="overlay"
       class="fixed inset-0 z-50 hidden">

    <div class="absolute inset-0 bg-black/40"
         data-action="click->bus-selector#close"></div>

    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-sm
                bg-white rounded-t-3xl px-6 pt-6 pb-10 shadow-xl">

      <%= render "shared/bus_selector_sheet",
                 regions: @selector_regions,
                 current_region_slug: params[:region_slug],
                 current_stop_id: params[:stop_id],
                 close_action: "click->bus-selector#close" %>
    </div>
  </div>

</div>
