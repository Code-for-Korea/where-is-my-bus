<div data-controller="bus-selector"
     data-bus-selector-select-error-message-value="<%= t('shared.bus_selector_sheet.select_error') %>">

  <div class="flex flex-col min-h-screen pr-6 pl-0 pt-12 pb-10">

    <%# 헤더 %>
    <div class="flex items-center gap-2 mb-6">
      <%= link_to root_path, class: "text-gray-400 hover:text-gray-600 transition-colors text-xl leading-none flex-shrink-0 pl-4" do %>
        ←
      <% end %>
      <h1 class="text-lg font-bold text-gray-900 truncate"><%= t("pages.about.title") %></h1>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500 flex-shrink-0">
        <path d="M8 6v6"/><path d="M15 6v6"/><path d="M2 12h19.6"/>
        <path d="M18 18h3s.5-1.7.8-2.8c.1-.4.2-.8.2-1.2 0-.4-.1-.8-.2-1.2l-1.4-5C20.1 6.8 19.1 6 18 6H4a2 2 0 0 0-2 2v10h3"/>
        <circle cx="7" cy="18" r="2"/><path d="M9 18h5"/><circle cx="16" cy="18" r="2"/>
      </svg>
      <%= render "shared/locale_switcher" %>
    </div>

    <%# 버스 이미지 %>
    <div class="-mx-6 mb-6 bg-white" style="mix-blend-mode: multiply;">
      <img src="/bus_hero.png?v=2" alt="<%= t('pages.about.hero_alt') %>"
           class="w-full block"
           style="filter: brightness(1.1);">
    </div>

    <%# 서비스 설명 %>
    <p class="text-base font-semibold text-gray-700 leading-snug mb-6">
      <%= t("pages.about.mission") %>
    </p>

    <hr class="border-gray-100 mb-6">

    <%# 인용구 %>
    <div class="border-l-4 border-indigo-200 pl-4 mb-6">
      <p class="text-sm text-gray-600 leading-relaxed mb-2">
        <%= t("pages.about.quote_text") %>
      </p>
      <p class="text-xs text-gray-400"><%= t("pages.about.quote_source") %></p>
    </div>

    <%# 문제 설명 %>
    <div class="mb-6 space-y-3">
      <p class="text-sm text-gray-600 leading-relaxed">
        <%= t("pages.about.problem_stat").html_safe %>
      </p>
      <p class="text-sm text-gray-600 leading-relaxed">
        <%= t("pages.about.problem_cycle") %>
      </p>
    </div>

    <%# 기술 설명 — 박스 위 1문장 %>
    <p class="text-sm text-gray-600 leading-relaxed mb-3">
      <%= t("pages.about.tech_intro").html_safe %>
    </p>

    <%# 기술 설명 박스 %>
    <div class="bg-indigo-50 rounded-xl p-4 mb-3">
      <p class="text-sm font-bold text-indigo-800 mb-3"><%= t("pages.about.tech_box_title") %></p>
      <div class="flex items-center justify-between text-xs text-indigo-600 font-medium mb-3">
        <span class="text-center"><%= t("pages.about.tech_step1").html_safe %></span>
        <span class="text-indigo-300">→</span>
        <span class="text-center"><%= t("pages.about.tech_step2").html_safe %></span>
        <span class="text-indigo-300">→</span>
        <span class="text-center"><%= t("pages.about.tech_step3").html_safe %></span>
      </div>
      <p class="text-xs text-indigo-700 leading-relaxed mt-3">
        <%= t("pages.about.tech_detail") %>
      </p>
    </div>

    <%# 기술 설명 — 박스 아래 2문장 %>
    <p class="text-sm text-gray-600 leading-relaxed mt-3 mb-6">
      <%= t("pages.about.tech_outro").html_safe %>
    </p>

    <hr class="border-gray-100 mb-6">

    <%# 제공 지역 %>
    <div class="mb-8">
      <% total_routes = @regions.sum { |r| r.buses.select(&:active?).sum { |b| b.routes.size } } %>
      <p class="text-sm font-bold text-gray-800 mb-3">
        <%= t("pages.about.coverage_title_html", regions_count: @regions.count, routes_count: total_routes).html_safe %>
      </p>
      <ul class="space-y-2">
        <% @regions.each do |region| %>
          <% entries = region.areas.any? ? region.areas.map { |a| "#{region.display_name} #{a.name}" } : [region.display_name] %>
          <% entries.each do |label| %>
            <li class="flex items-center gap-2 text-sm text-gray-600">
              <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 flex-shrink-0"></span>
              <%= label %> <%= t("pages.about.region_route_suffix") %>
            </li>
          <% end %>
        <% end %>
      </ul>
    </div>

    <%# 버스 노선 확인 버튼 — 바텀시트 직접 열기 %>
    <button data-action="click->bus-selector#open"
            class="block w-full bg-indigo-600 hover:bg-indigo-700 text-white
                   font-bold text-lg text-center py-4 rounded-2xl transition-colors mb-6">
      <%= t("pages.about.check_routes_button") %>
    </button>

    <%# 주의 안내 %>
    <div class="bg-gray-50 rounded-xl p-4 mb-10 text-xs text-gray-500 leading-relaxed">
      <p class="font-bold text-gray-700 mb-1"><%= t("pages.about.caution_title") %></p>
      <p><%= t("pages.about.caution_body") %></p>
    </div>

    <%# 하단 파트너 %>
    <div class="mt-auto">
      <p class="text-center text-xs text-gray-400 mb-3"><%= t("pages.about.partners_together") %></p>
      <div class="flex justify-center items-center gap-8 mb-4">
        <div class="text-center">
          <p class="text-xs font-bold text-gray-600"><%= t("pages.about.nia_name") %></p>
          <p class="text-xs text-gray-400"><%= t("pages.about.nia_full") %></p>
        </div>
        <div class="text-center">
          <p class="text-xs font-bold text-gray-600"><%= t("pages.about.molit") %></p>
        </div>
      </div>
      <div class="border-t border-gray-100 pt-4 mb-3">
        <div class="flex items-center justify-between text-xs text-gray-400">
          <span><%= t("pages.about.footer_makers") %></span>
          <span>|</span>
          <span><%= t("pages.about.footer_driver") %></span>
          <span>|</span>
          <span><%= t("pages.about.footer_terms") %></span>
        </div>
      </div>
      <div class="flex justify-center">
        <img src="/codeforkorea.webp" alt="CODE FOR KOREA" class="h-7 w-auto opacity-75">
      </div>
    </div>

  </div>

  <%# 바텀시트 오버레이 %>
  <div data-bus-selector-target="overlay"
       class="fixed inset-0 z-50 hidden">

    <div class="absolute inset-0 bg-black/40"
         data-action="click->bus-selector#close"></div>

    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-sm
                bg-white rounded-t-3xl px-6 pt-6 pb-10 shadow-xl">

      <%= render "shared/bus_selector_sheet",
                 regions: @selector_regions,
                 current_region_slug: nil,
                 current_stop_id: nil,
                 close_action: "click->bus-selector#close" %>
    </div>
  </div>

</div>
