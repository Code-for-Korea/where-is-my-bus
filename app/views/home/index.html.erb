<% content_for :title, "내 버스는 언제 올까?" %>

<div class="text-center py-10">
  <div class="text-5xl mb-4">🚌</div>
  <h1 class="text-3xl font-bold mb-2">내 버스는 언제 올까?</h1>
  <p class="text-gray-500 mb-8">버스가 언제 올지 막연히 기다려야 하는<br>시골버스의 불편함을 해결합니다.</p>

  <div class="mb-6">
    <%= link_to "🚌 버스 위치 확인하기", service_path, class: "text-sm text-brand-600 underline hover:no-underline" %>
  </div>

  <% unless authenticated? %>
    <div class="flex items-center justify-center gap-3">
      <%= link_to "회원가입", new_registration_path,
            class: "px-5 py-2.5 rounded-lg bg-indigo-600 text-white font-medium hover:bg-indigo-700" %>
      <%= link_to "로그인", new_session_path,
            class: "px-5 py-2.5 rounded-lg bg-white border border-gray-300 text-gray-700 font-medium hover:bg-gray-50" %>
    </div>
  <% else %>
    <p class="text-gray-700"><span class="font-medium"><%= Current.user.email_address %></span> 님, 환영합니다.</p>
    <% if Current.user.operator? %>
      <%= link_to "관리자 페이지로 이동", admin_root_path,
            class: "inline-block mt-4 px-5 py-2.5 rounded-lg bg-indigo-600 text-white font-medium hover:bg-indigo-700" %>
    <% end %>
  <% end %>
</div>
