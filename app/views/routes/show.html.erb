<% content_for :title, "#{@route.name} 버스 · 내 버스는 언제 올까?" %>

<div class="flex-1 flex flex-col">
  <h1 class="px-6 py-4 text-lg font-bold text-gray-900">내 버스는 언제 올까?</h1>

  <!-- 노선 요약 (연보라) -->
  <div class="bg-brand-50 px-6 py-6">
    <p class="text-sm text-gray-400">여기는! <%= @route.region.name %> <span class="text-gray-300">|</span> <%= @route.area.name.split.first %></p>
    <div class="mt-1 flex items-baseline gap-2">
      <span class="text-3xl font-extrabold text-brand-500"><%= @route.name %> 버스</span>
      <%= link_to "▾", stops_route_path(@route), class: "text-brand-400 text-xl" %>
    </div>
    <p class="text-2xl font-bold text-gray-900 mt-0.5"><%= @next_stop&.name || "정류장 정보 없음" %></p>

    <%= button_to like_route_path(@route), method: :post,
          class: "mt-3 inline-flex items-center gap-1.5 font-semibold #{@liked ? 'text-brand-500' : 'text-gray-400'}" do %>
      👍 <%= number_with_delimiter(@route.likes_count) %>
    <% end %>
  </div>

  <!-- 실시간 위치 (블루) — ⚠️ 예시 값 (운전자 앱 연동 전) -->
  <div class="flex-1 bg-live-500 px-6 py-8 text-white flex flex-col">
    <p class="text-white/70"><%= @route.name %> 버스는 지금 어디?</p>
    <% if @stops.any? %>
      <p class="mt-6 text-xl font-medium"><%= @stops_before %>정거장 전에 있습니다.</p>
      <p class="text-4xl font-extrabold mt-1">약 <%= @eta_minutes %>분 후 도착예정</p>
      <p class="mt-2 text-xs text-white/50">* 실시간 위치는 준비 중이며 현재 값은 예시입니다.</p>

      <div class="flex justify-end mt-4">
        <%= link_to "자세히보기", stops_route_path(@route),
              class: "px-3 py-1.5 rounded-lg bg-brand-500 text-white text-sm font-medium" %>
      </div>

      <!-- 진행 바 -->
      <div class="mt-auto pt-10">
        <div class="flex items-center justify-end gap-2 mb-1 pr-1">
          <span class="text-lg">🚌</span><span class="text-xl">📍</span>
        </div>
        <div class="relative h-0.5 bg-white/50 rounded-full">
          <% 3.times do |i| %>
            <span class="absolute -top-1.5 w-3.5 h-3.5 rounded-full bg-white border-2 border-live-500"
                  style="left: <%= i * 50 %>%; margin-left: <%= i == 2 ? '-14px' : '0' %>"></span>
          <% end %>
        </div>
      </div>
    <% else %>
      <p class="mt-6 text-white/80">아직 등록된 정류장이 없습니다.</p>
    <% end %>
  </div>
</div>
