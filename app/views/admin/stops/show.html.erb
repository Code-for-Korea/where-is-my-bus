<% content_for :page_title, @stop.name %>

<div class="bg-white rounded-xl border border-gray-200 p-6 max-w-lg space-y-4">
  <div>
    <div class="text-xs text-gray-400">노선</div>
    <div class="font-medium"><%= @stop.route.area.full_name %> · <%= @stop.route.name %></div>
  </div>
  <div>
    <div class="text-xs text-gray-400">정류장명</div>
    <div class="font-medium"><%= @stop.name %></div>
  </div>
  <div class="flex gap-8">
    <div>
      <div class="text-xs text-gray-400">순서</div>
      <div class="font-medium"><%= @stop.sequence %></div>
    </div>
    <div>
      <div class="text-xs text-gray-400">좌표</div>
      <div class="font-medium">
        <% if @stop.coordinates? %>
          <span class="font-mono text-sm"><%= @stop.lat %>, <%= @stop.lng %></span>
        <% else %>
          <span class="text-amber-600 text-sm">미등록</span>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2 border-t border-gray-100">
    <%= link_to "수정", edit_admin_stop_path(@stop),
          class: "px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700" %>
    <%= link_to "목록", admin_stops_path(route_id: @stop.route_id), class: "text-sm text-gray-500 hover:text-gray-900" %>
  </div>
</div>
