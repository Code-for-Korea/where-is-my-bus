<%= form_with model: [:admin, region], class: "space-y-5 max-w-lg" do |f| %>
  <% if region.errors.any? %>
    <div class="rounded-lg bg-red-50 text-red-800 px-4 py-3 text-sm">
      <p class="font-medium mb-1"><%= region.errors.count %>개의 오류가 있습니다.</p>
      <ul class="list-disc list-inside">
        <% region.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "이름", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, placeholder: "예: 전라남도",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :position, "정렬 순서", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.number_field :position,
          class: "w-32 rounded-lg border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-gray-400">숫자가 작을수록 먼저 표시됩니다.</p>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "취소", admin_regions_path, class: "text-sm text-gray-500 hover:text-gray-900" %>
  </div>
<% end %>
