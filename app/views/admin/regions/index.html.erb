<% content_for :page_title, "시·도" %>

<div class="flex items-center justify-between mb-5">
  <p class="text-sm text-gray-500">총 <%= @regions.size %>개</p>
  <%= link_to "시·도 추가", new_admin_region_path,
        class: "inline-flex items-center px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700" %>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 text-gray-500 text-left">
      <tr>
        <th class="px-5 py-3 font-medium w-20">순서</th>
        <th class="px-5 py-3 font-medium">이름</th>
        <th class="px-5 py-3 font-medium w-32 text-right">관리</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @regions.each do |region| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-gray-400"><%= region.position %></td>
          <td class="px-5 py-3 font-medium">
            <%= link_to region.name, admin_region_path(region), class: "text-indigo-600 hover:underline" %>
          </td>
          <td class="px-5 py-3 text-right space-x-3">
            <%= link_to "수정", edit_admin_region_path(region), class: "text-gray-500 hover:text-gray-900" %>
            <%= button_to "삭제", admin_region_path(region), method: :delete,
                  form: { data: { turbo_confirm: "삭제하시겠습니까?" }, class: "inline" },
                  class: "text-red-500 hover:text-red-700" %>
          </td>
        </tr>
      <% end %>
      <% if @regions.empty? %>
        <tr><td colspan="3" class="px-5 py-10 text-center text-gray-400">등록된 시·도가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
