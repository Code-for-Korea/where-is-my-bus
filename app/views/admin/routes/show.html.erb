<% content_for :page_title, "#{@route.area.full_name} · #{@route.name}" %>

<div class="bg-white rounded-xl border border-gray-200 p-6 max-w-lg space-y-4">
  <div>
    <div class="text-xs text-gray-400">운행지역</div>
    <div class="font-medium"><%= @route.area.full_name %></div>
  </div>
  <div>
    <div class="text-xs text-gray-400">노선명</div>
    <div class="font-medium"><%= @route.name %></div>
  </div>
  <div class="flex gap-8">
    <div>
      <div class="text-xs text-gray-400">배차간격</div>
      <div class="font-medium"><%= @route.headway_minutes ? "#{@route.headway_minutes}분" : "—" %></div>
    </div>
    <div>
      <div class="text-xs text-gray-400">추천 수</div>
      <div class="font-medium"><%= number_with_delimiter(@route.likes_count) %></div>
    </div>
    <div>
      <div class="text-xs text-gray-400">정류장 수</div>
      <div class="font-medium">
        <%= link_to "#{@route.stops_count}개", admin_stops_path(route_id: @route.id), class: "text-indigo-600 hover:underline" %>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2 border-t border-gray-100">
    <%= link_to "정류장 관리", admin_stops_path(route_id: @route.id),
          class: "px-4 py-2 rounded-lg bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200" %>
    <%= link_to "수정", edit_admin_route_path(@route),
          class: "px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700" %>
    <%= link_to "목록", admin_routes_path, class: "text-sm text-gray-500 hover:text-gray-900" %>
  </div>
</div>
