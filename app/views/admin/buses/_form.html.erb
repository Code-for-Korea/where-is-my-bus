<%= form_with model: [:admin, bus], class: "space-y-5 max-w-lg" do |f| %>
  <% if bus.errors.any? %>
    <div class="rounded-lg bg-red-50 text-red-800 px-4 py-3 text-sm">
      <p class="font-medium mb-1"><%= bus.errors.count %>개의 오류가 있습니다.</p>
      <ul class="list-disc list-inside">
        <% bus.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :area_id, "운행지역", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.collection_select :area_id, Area.includes(:region).all, :id, :full_name, { prompt: "운행지역 선택" },
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :license_plate, "번호판", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :license_plate, placeholder: "예: 경남 70바 1234",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :bus_number, "버스 번호 (노선번호)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :bus_number, placeholder: "예: 35번",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-gray-400">서비스 화면에 "○○번 버스"로 표시됩니다.</p>
  </div>

  <div>
    <%= f.label :status, "운행 상태", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :status,
          [["운행중 (active)", "active"], ["중지 (inactive)", "inactive"], ["삭제됨 (deleted)", "deleted"]],
          {}, class: "w-56 rounded-lg border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-gray-400">"운행중"인 차량만 서비스 노선 선택에 노출됩니다.</p>
  </div>

  <div>
    <%= f.label :pin, "PIN (4~6자리 숫자)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :pin, inputmode: "numeric", placeholder: "예: 1234",
          class: "w-40 rounded-lg border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-gray-400">운전자가 앱에서 운행 시작 시 입력하는 인증 번호입니다.</p>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "취소", admin_buses_path, class: "text-sm text-gray-500 hover:text-gray-900" %>
  </div>
<% end %>
