<% content_for :page_title, @bus.license_plate %>

<div class="bg-white rounded-xl border border-gray-200 p-6 max-w-lg space-y-4">
  <div>
    <div class="text-xs text-gray-400">운행지역</div>
    <div class="font-medium"><%= @bus.area.full_name %></div>
  </div>
  <div>
    <div class="text-xs text-gray-400">번호판</div>
    <div class="font-medium"><%= @bus.license_plate %></div>
  </div>
  <div>
    <div class="text-xs text-gray-400">PIN</div>
    <div class="font-medium font-mono"><%= @bus.pin %></div>
  </div>

  <div class="flex items-center gap-3 pt-2 border-t border-gray-100">
    <%= link_to "수정", edit_admin_bus_path(@bus),
          class: "px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700" %>
    <%= link_to "목록", admin_buses_path, class: "text-sm text-gray-500 hover:text-gray-900" %>
  </div>
</div>
