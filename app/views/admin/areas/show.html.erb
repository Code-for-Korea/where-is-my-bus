<% content_for :page_title, @area.full_name %>

<div class="bg-white rounded-xl border border-gray-200 p-6 max-w-lg space-y-4">
  <div>
    <div class="text-xs text-gray-400">시·도</div>
    <div class="font-medium"><%= @area.region.name %></div>
  </div>
  <div>
    <div class="text-xs text-gray-400">운행지역명</div>
    <div class="font-medium"><%= @area.name %></div>
  </div>
  <div class="flex gap-8">
    <div>
      <div class="text-xs text-gray-400">정렬 순서</div>
      <div class="font-medium"><%= @area.position %></div>
    </div>
    <div>
      <div class="text-xs text-gray-400">노선 수</div>
      <div class="font-medium">
        <%= link_to "#{@area.routes_count}개", admin_routes_path(area_id: @area.id), class: "text-indigo-600 hover:underline" %>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2 border-t border-gray-100">
    <%= link_to "노선 추가", new_admin_route_path(area_id: @area.id),
          class: "px-4 py-2 rounded-lg bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200" %>
    <%= link_to "수정", edit_admin_area_path(@area),
          class: "px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700" %>
    <%= link_to "목록", admin_areas_path, class: "text-sm text-gray-500 hover:text-gray-900" %>
  </div>
</div>
